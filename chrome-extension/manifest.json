{
  "manifest_version": 3,
  "name": "Treehouse Intel",
  "version": "1.0.0",
  "description": "Content freshness intelligence for teamtreehouse.com",
  "permissions": ["activeTab"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://teamtreehouse.com/*", "*://www.teamtreehouse.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
